# PostgreSQL
POSTGRES_DB=gestionmateriel
POSTGRES_USER=gestionmateriel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend
ENV=production
DATABASE_URL=postgresql+psycopg://gestionmateriel:CHANGE_ME_STRONG_PASSWORD@db:5432/gestionmateriel
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRE_MINUTES=480
FRONTEND_BASE_URL=https://gestion-materiel.swissworktogether.ch
CORS_ORIGINS=https://gestion-materiel.swissworktogether.ch

# Audit / RGPD
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=90
AUDIT_IP_SALT=CHANGE_ME_RANDOM_SALT
